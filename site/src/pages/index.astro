---
import Base from '../layouts/Base.astro';
import { corpus, scorecard, href } from '../lib/corpus.js';
const { meta, groups, entries } = corpus();
const reviewed = entries.filter((e) => e.status === 'reviewed').length;
const readingCount = entries.reduce((n, e) => n + (e.reading?.length || 0), 0);
const libCount = new Set(entries.flatMap((e) => (e.detect || []).map((d) => d.pkg)).filter((p) => !p.includes('*'))).size;
const sc = scorecard();
const high = sc?.tiers?.high;
const recent = [...entries].sort((a, b) => String(b.updated).localeCompare(String(a.updated))).slice(0, 3);
// Recommendation of the week: deterministic — the most recently re-verified reviewed entry
const pick = [...entries].filter((e) => e.status === 'reviewed')
  .sort((a, b) => String(b.updated).localeCompare(String(a.updated)))[0];
// first clause only — split at real sentence boundaries (". ", ";", spaced em-dash),
// never at version dots like "19.2"
const clause = (pick.recommend?.default || '').split(/\.\s|;|\s—\s/)[0].trim();
const pickHeadline = clause.length > 110 ? clause.slice(0, 109) + '…' : clause;
const stats = [
  { label: 'decisions', value: entries.length, to: 'entries/', go: 'Browse' },
  { label: 'verified readings', value: readingCount, to: 'reading/', go: 'Read' },
  { label: 'libraries tracked', value: libCount, to: 'libraries/', go: 'Compare' },
  ...(high?.score != null ? [{ label: 'calibration · high tier', value: `${high.score}%`, to: 'scorecard/', go: 'Inspect' }] : []),
];
---
<Base>
  <div class="hero hero-home" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(21rem, 1fr)); gap:2.5rem; align-items:center;">
    <div style="flex: 1.15">
      <p class="label-caps" style="margin:0">decision engine · react &amp; react native</p>
      <h1>The React ecosystem, as an encyclopedia that shows its work.<span class="blink" aria-hidden="true">▊</span></h1>
      <p class="muted">{meta.one_liner} Every recommendation is <strong style="color:var(--fg)">context-keyed</strong>,
      every load-bearing fact carries a <strong style="color:var(--fg)">verified-on date and a primary source</strong>,
      and the corpus <a href={href('scorecard/')}>grades its own forecasts</a>.</p>

      <div class="statline">
        {stats.map((s) => (
          <a href={href(s.to)}><strong>{s.value}</strong>{s.label}</a>
        ))}
      </div>

      <p style="display:flex; gap:.7rem; flex-wrap:wrap">
        <a class="btn" href={href('entries/')}>Browse entries →</a>
        <a class="btn ghost" href={href('doctor/')}>Analyze package.json</a>
      </p>
    </div>

    <div style="max-width:34rem; justify-self:center; width:100%">
      <div class="term" role="img" aria-label="Example react-brain doctor run: detected ecosystem choices compared against the encyclopedia, with fit marks and gaps">
        <div class="term-bar" aria-hidden="true"><i></i><i></i><i></i><span>react-brain — doctor</span></div>
        <pre aria-hidden="true"><span class="t-p">$ npx react-brain doctor .</span>

<span class="t-dim">ourpot (v1.4) · react-native · production · 41 deps</span>

  state        Zustand              <span class="t-ok">✓ aligned</span>
  lists        FlashList            <span class="t-ok">✓ aligned</span>
  nav          Expo Router          <span class="t-ok">✓ aligned</span>
  data         Hypercore (P2P)      <span class="t-warn">~ contextual</span>
  animation    Reanimated 4         <span class="t-ok">✓ aligned</span>
  rn-versions  0.83 → 0.86          <span class="t-warn">↗ review</span>

<span class="t-dim">2 source signals · 1 gap · docs: entries/rn-versions</span></pre>
      </div>
      <p class="meta" style="text-align:center; margin-top:.5rem">
        <a href={href('architecture/')} style="color:var(--muted)">how it works →</a>
      </p>
    </div>
  </div>

  <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(21rem, 1fr)); gap:0 4rem; align-items:start">
    <div>
      <h2>Browse by decision</h2>
      <div class="rows">
        {groups.map((g) => (
          <a class="row" href={href(`entries/#${g.id}`)} style="display:flex; justify-content:space-between; gap:1rem; align-items:baseline">
            <span class="row-title" style="font-family:var(--font-head); font-weight:600; color:var(--bright)">{g.label.split(' — ')[0].split(' (')[0]}</span>
            <span class="meta">{g.entries.length}</span>
          </a>
        ))}
      </div>

      <h2>Recently updated</h2>
      <div class="rows">
        {recent.map((e) => (
          <a class="row" href={href(`entries/${e.slug}/`)}>
            <span class="row-title" style="font-family:var(--font-head); font-weight:600; color:var(--bright)">{e.slug}</span>
            <span class="meta" style="margin-left:.8rem">{String(e.updated)}</span>
            <span class="muted" style="display:block; font-size:.88rem; margin-top:.15rem">{e.topic}</span>
          </a>
        ))}
      </div>
    </div>
    <div>

      <h2>This week</h2>
      <div class="card pick">
        <p class="label-caps" style="margin:0 0 .55rem">recommendation of the week</p>
        <h3 style="margin:0; font: 600 1.1rem/1.35 var(--font-head); color:var(--bright)">{pickHeadline}</h3>
        <p class="meta" style="margin:.45rem 0 .75rem">
          {pick.slug} · <span class={`badge ${pick.confidence}`}>{pick.confidence}</span> · verified {String(pick.updated)}
        </p>
        <a href={href(`entries/${pick.slug}/#explanation`)}>Read the reasoning →</a>
      </div>
      <h2>Quick start</h2>
      <pre><span class="t-p">$</span> npx react-brain doctor .      <span class="t-dim"># assess a repo</span>
<span class="t-p">$</span> npx react-brain stack --rn    <span class="t-dim"># compose a stack</span>
<span class="t-p">$</span> npx react-brain learn .       <span class="t-dim"># learning path</span></pre>
      <p class="muted" style="font-size:.9rem">Organized by decision, not by article — {readingCount} deep-dives
      cited as evidence, every default a dated prediction on the
      <a href={href('scorecard/')}>scorecard</a>, and <a href={href('methodology/')}>nothing asserted casually</a>.</p>
    </div>
  </div>
</Base>


<style>
  .hero-home { position: relative; }
  .hero-home::before { content: ""; position: absolute; inset: -2rem -3rem; z-index: -1; pointer-events: none;
    background-image: linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(78% 90% at 55% 30%, black, transparent 80%); }
  .hero-home > * { animation: rise .55s ease-out both; }
  .hero-home > *:nth-child(2) { animation-delay: .12s; }
  @keyframes rise { from { opacity: 0; transform: translateY(16px); } }
</style>
