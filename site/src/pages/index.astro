---
import Base from '../layouts/Base.astro';
import { corpus, scorecard, href } from '../lib/corpus.js';
const { meta, groups, entries } = corpus();
const reviewed = entries.filter((e) => e.status === 'reviewed').length;
const readingCount = entries.reduce((n, e) => n + (e.reading?.length || 0), 0);
const libCount = new Set(entries.flatMap((e) => (e.detect || []).map((d) => d.pkg)).filter((p) => !p.includes('*'))).size;
const sc = scorecard();
const high = sc?.tiers?.high;
const recent = [...entries].sort((a, b) => String(b.updated).localeCompare(String(a.updated))).slice(0, 3);
// freshness — computed from the corpus itself at build time (the site redeploys on every harvest)
const lastVerified = recent[0] ? String(recent[0].updated) : '';
const now = Date.now();
const updated7 = entries.filter((e) => e.updated && now - new Date(String(e.updated)).getTime() < 7 * 864e5).length;
// Recommendation of the week: deterministic — the most recently re-verified reviewed entry
const pick = [...entries].filter((e) => e.status === 'reviewed')
  .sort((a, b) => String(b.updated).localeCompare(String(a.updated)))[0];
// first clause only — split at real sentence boundaries (". ", ";", spaced em-dash),
// never at version dots like "19.2"
const clause = (pick.recommend?.default || '').split(/\.\s|;|\s—\s/)[0].trim();
const pickHeadline = clause.length > 110 ? clause.slice(0, 109) + '…' : clause;
const stats = [
  { label: 'decisions', value: entries.length, to: 'entries/', go: 'Browse' },
  { label: 'verified readings', value: readingCount, to: 'reading/', go: 'Read' },
  { label: 'libraries tracked', value: libCount, to: 'libraries/', go: 'Compare' },
  ...(high?.score != null ? [{ label: 'calibration · high tier', value: `${high.score}%`, to: 'scorecard/', go: 'Inspect' }] : []),
];
---
<Base>
  <div class="hero hero-home" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(21rem, 1fr)); gap:2.5rem; align-items:center;">
    <div style="flex: 1.15">
      <p class="label-caps" style="margin:0">engineering intelligence · react &amp; react native</p>
      <h1>React decisions, with receipts.<span class="blink" aria-hidden="true">▊</span></h1>
      <p class="muted">Hundreds of libraries, conflicting takes, advice that quietly rots.
      react-brain digests the ecosystem continuously and turns it into
      <strong style="color:var(--fg)">context-keyed recommendations</strong> — every load-bearing fact
      carries a <strong style="color:var(--fg)">verified-on date and a primary source</strong>, and every
      default is a forecast <a href={href('scorecard/')}>graded on the public scorecard</a>.</p>

      <div class="statline">
        {stats.map((s) => (
          <a href={href(s.to)}><strong>{s.value}</strong>{s.label}</a>
        ))}
      </div>

      <p style="display:flex; gap:.7rem; flex-wrap:wrap">
        <a class="btn" href={href('doctor/')}>Analyze your project →</a>
        <a class="btn ghost" href={href('entries/')}>Browse decisions</a>
      </p>
      <p class="meta" style="margin-top:.4rem">ecosystem pulse: last verification {lastVerified} · {updated7} decision{updated7 === 1 ? '' : 's'} re-verified this week · 6 sources digested</p>
    </div>

    <div style="max-width:34rem; justify-self:center; width:100%">
      <div class="term" role="img" aria-label="Example react-brain doctor run: detected ecosystem choices compared against the corpus, with fit marks and gaps">
        <div class="term-bar" aria-hidden="true"><i></i><i></i><i></i><span>react-brain — doctor</span></div>
        <pre aria-hidden="true"><span class="t-p">$ npx react-brain doctor .</span>

<span class="t-dim">ourpot (v1.4) · react-native · production · 41 deps</span>

  state        Zustand              <span class="t-ok">✓ aligned</span>
  lists        FlashList            <span class="t-ok">✓ aligned</span>
  nav          Expo Router          <span class="t-ok">✓ aligned</span>
  data         Hypercore (P2P)      <span class="t-warn">~ contextual</span>
  animation    Reanimated 4         <span class="t-ok">✓ aligned</span>
  rn-versions  0.83 → 0.86          <span class="t-warn">↗ review</span>

<span class="t-dim">2 source signals · 1 gap · docs: entries/rn-versions</span></pre>
      </div>
      <p class="meta" style="text-align:center; margin-top:.5rem">
        <a href={href('architecture/')} style="color:var(--muted)">how it works →</a>
      </p>
    </div>
  </div>

  <div class="pipeline" aria-label="How knowledge flows through react-brain">
    <span class="p-stage">6 newsletters · release notes · npm · 34 shipped apps</span>
    <span class="p-arrow" aria-hidden="true">→</span>
    <span class="p-stage">every claim fetch-verified &amp; dated</span>
    <span class="p-arrow" aria-hidden="true">→</span>
    <span class="p-stage">{entries.length} context-keyed decisions</span>
    <span class="p-arrow" aria-hidden="true">→</span>
    <span class="p-stage">doctor · migrate · review · MCP</span>
    <a class="p-more" href={href('methodology/')}>methodology →</a>
  </div>

  <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(21rem, 1fr)); gap:0 4rem; align-items:start">
    <div>
      <h2>Browse by decision</h2>
      <div class="rows">
        {groups.map((g) => (
          <a class="row" href={href(`entries/#${g.id}`)} style="display:flex; justify-content:space-between; gap:1rem; align-items:baseline">
            <span class="row-title" style="font-family:var(--font-head); font-weight:600; color:var(--bright)">{g.label.split(' — ')[0].split(' (')[0]}</span>
            <span class="meta">{g.entries.length}</span>
          </a>
        ))}
      </div>

      <h2>Recently updated</h2>
      <div class="rows">
        {recent.map((e) => (
          <a class="row" href={href(`entries/${e.slug}/`)}>
            <span class="row-title" style="font-family:var(--font-head); font-weight:600; color:var(--bright)">{e.slug}</span>
            <span class="meta" style="margin-left:.8rem">{String(e.updated)}</span>
            <span class="muted" style="display:block; font-size:.88rem; margin-top:.15rem">{e.topic}</span>
          </a>
        ))}
      </div>
    </div>
    <div>

      <h2>This week</h2>
      <div class="card pick">
        <p class="label-caps" style="margin:0 0 .55rem">recommendation of the week</p>
        <h3 style="margin:0; font: 600 1.1rem/1.35 var(--font-head); color:var(--bright)">{pickHeadline}</h3>
        <p class="meta" style="margin:.45rem 0 .75rem">
          {pick.slug} · <span class={`badge ${pick.confidence}`}>{pick.confidence}</span> · verified {String(pick.updated)}
        </p>
        <a href={href(`entries/${pick.slug}/#explanation`)}>Read the reasoning →</a>
      </div>
      <h2>Quick start</h2>
      <pre><span class="t-p">$</span> npx react-brain doctor .      <span class="t-dim"># assess a repo, ranked priorities</span>
<span class="t-p">$</span> npx react-brain migrate .     <span class="t-dim"># sequenced upgrade plan</span>
<span class="t-p">$</span> npx react-brain review . --ci <span class="t-dim"># block dead deps in CI</span></pre>
      <p class="muted" style="font-size:.9rem">Organized by decision, not by article — {readingCount} deep-dives
      cited as evidence, every default a dated prediction on the
      <a href={href('scorecard/')}>scorecard</a>, and <a href={href('methodology/')}>nothing asserted casually</a>.</p>
    </div>
  </div>

  <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(21rem, 1fr)); gap:0 4rem; align-items:start">
    <div>
      <h2>One corpus, every surface</h2>
      <pre><span class="t-dim"># this website — press ⌘K for the console</span>

<span class="t-dim"># your terminal, zero install</span>
<span class="t-p">$</span> npx -y @heart-it/react-brain doctor .

<span class="t-dim"># your coding agent — 9 MCP tools</span>
<span class="t-p">$</span> claude mcp add react-brain -- npx -y @heart-it/react-brain mcp

<span class="t-dim"># your CI — dead/deprecated dep adds fail the build, with receipts</span>
<span class="t-p">$</span> npx -y @heart-it/react-brain review . --base=origin/main --ci</pre>
      <p class="meta">package: <a href="https://www.npmjs.com/package/@heart-it/react-brain" rel="noopener">npmjs.com/package/@heart-it/react-brain</a></p>
    </div>
    <div>
      <h2>Not another model answer</h2>
      <div class="rows">
        <div class="row"><span class="row-title vs-a">a model predicts from training data</span>
          <span class="muted" style="display:block; font-size:.88rem; margin-top:.15rem">the corpus <strong style="color:var(--fg)">fetch-verifies against primary sources</strong>, and stamps the date</span></div>
        <div class="row"><span class="row-title vs-a">a model's confidence is tone</span>
          <span class="muted" style="display:block; font-size:.88rem; margin-top:.15rem">here confidence is a <strong style="color:var(--fg)">forecast graded in public</strong> — <a href={href('scorecard/')}>the scorecard</a></span></div>
        <div class="row"><span class="row-title vs-a">a model's knowledge freezes at cutoff</span>
          <span class="muted" style="display:block; font-size:.88rem; margin-top:.15rem">the corpus is <strong style="color:var(--fg)">re-verified weekly</strong> from 6 cross-checked sources — <a href={href('changelog/')}>changelog</a></span></div>
      </div>
      <p class="muted" style="font-size:.9rem">Don’t take the framing on faith — <a href={href('benchmark/')}>the staleness benchmark</a> is
      published and reproducible: 35 questions built from verified, dated corpus facts, a deterministic
      rubric (no judge model), one command with your own API key. First public results are pending —
      run it before we do.</p>
    </div>
  </div>
</Base>


<style>
  .hero-home { position: relative; }
  .hero-home::before { content: ""; position: absolute; inset: -2rem -3rem; z-index: -1; pointer-events: none;
    background-image: linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(78% 90% at 55% 30%, black, transparent 80%); }
  .hero-home > * { animation: rise .55s ease-out both; }
  .hero-home > *:nth-child(2) { animation-delay: .12s; }
  @keyframes rise { from { opacity: 0; transform: translateY(16px); } }

  .pipeline { display: flex; flex-wrap: wrap; align-items: baseline; gap: .35rem .6rem;
    margin: 2.6rem 0 2.2rem; padding: .85rem 1rem; border-block: 1px solid var(--line);
    font: 500 .82rem/1.6 var(--font-mono); color: var(--muted); }
  .pipeline .p-stage { white-space: nowrap; }
  .pipeline .p-arrow { color: var(--accent); }
  .pipeline .p-more { margin-left: auto; color: var(--muted); text-decoration: none; }
  .pipeline .p-more:hover { color: var(--fg); }
  @media (max-width: 640px) { .pipeline .p-stage { white-space: normal; } .pipeline .p-more { margin-left: 0; } }

  .vs-a { font-family: var(--font-head); font-weight: 600; color: var(--bright); }
</style>
