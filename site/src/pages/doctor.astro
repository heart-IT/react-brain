---
import Base from '../layouts/Base.astro';
import { doctorData, BASE } from '../lib/corpus.js';
const { detectors, caps, migrations } = doctorData();
// same expected-domain list as tools/react-brain-doctor.mjs
const EXPECTED = {
  always: ['RB-E-STATE', 'RB-E-STYLING', 'RB-E-TESTING', 'RB-E-TYPESCRIPT', 'RB-E-DX', 'RB-E-NAV'],
  'react-native': ['RB-E-NATIVE'], react: [], both: ['RB-E-NATIVE'],
};
---
<Base title="react-brain — doctor (in browser)" description="Paste a package.json and get an ecosystem-fit report against the verified corpus — fully client-side.">
  <h1>Doctor <span class="badge">beta · runs in your browser</span></h1>
  <p class="muted prose">Paste a <code>package.json</code> — your dependencies are matched
  against the corpus's detection table, each detected choice is compared to the context-keyed
  recommendation, and expected-but-missing domains are flagged. Nothing leaves your browser. The full
  doctor (<code>npx react-brain doctor .</code>) adds what a browser can't: the legacy-API modernization
  scan and source-level signals. Ready to commit a choice? <a href={`${BASE}decide/`}>Generate a decision record</a>.</p>

  <label for="pkg" class="label-caps" style="display:block; color:var(--muted); margin-bottom:.4rem">Your package.json</label>
  <textarea id="pkg" placeholder='{"dependencies": {"react": "19.2.0", "zustand": "5.0.0", ...}}'></textarea>
  <p style="display:flex; gap:.7rem; align-items:center; flex-wrap:wrap">
    <button id="run">Analyze</button>
    <label class="btn ghost" style="cursor:pointer">Load a file<input id="file" type="file" accept=".json,application/json" style="display:none" /></label>
    <button id="sample" class="btn ghost">Try a sample</button>
    <button id="copy" hidden>Copy report</button>
  </p>
  <div id="out" aria-live="polite"></div>

  <script is:inline define:vars={{ detectors, caps, migrations, EXPECTED, BASE }}>
    // ports of tools/detect.mjs matchDetector() + fit() — same table, same semantics
    const matchDetector = (name) => {
      for (const d of detectors) {
        const pat = d[0];
        if (pat.endsWith('/*') || pat.endsWith('*')) { if (name.startsWith(pat.replace(/\*$/, ''))) return d; }
        else if (name === pat) return d;
      }
      return null;
    };
    const fit = (cap, tokens) => {
      const def = (cap.def || '').toLowerCase();
      const when = (cap.when || []).join(' || ').toLowerCase();
      if (tokens.some((x) => def.includes(x))) return '✓ aligned';
      if (tokens.some((x) => when.includes(x))) return '~ contextual';
      return '↗ review';
    };
    const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    let plainReport = '';

    document.getElementById('run').addEventListener('click', () => {
      const out = document.getElementById('out');
      let pkg;
      try { pkg = JSON.parse(document.getElementById('pkg').value); }
      catch { out.innerHTML = '<p class="muted">That is not valid JSON.</p>'; return; }
      const deps = { ...(pkg.dependencies || {}), ...(pkg.devDependencies || {}) };
      const names = Object.keys(deps);
      if (!names.length) { out.innerHTML = '<p class="muted">No dependencies found.</p>'; return; }
      const hasRN = 'react-native' in deps || 'expo' in deps;
      const platform = hasRN && 'react-dom' in deps ? 'both' : hasRN ? 'react-native' : 'react';

      const byEntry = {};
      for (const n of names) {
        const d = matchDetector(n);
        if (!d) continue;
        (byEntry[d[1]] ||= { labels: new Set(), tokens: new Set() });
        byEntry[d[1]].labels.add(d[2]);
        if (d[3]) byEntry[d[1]].tokens.add(d[3]);
      }
      const ids = Object.keys(byEntry);
      const lines = [`react-brain doctor — ${pkg.name || 'your app'} · platform: ${platform} · ${names.length} deps`];
      const tally = { '✓': 0, '~': 0, '↗': 0 };
      for (const id of ids) if (caps[id]) tally[fit(caps[id], [...byEntry[id].tokens])[0]]++;
      let html = `<p><strong>${esc(pkg.name || 'your app')}</strong> · platform: ${platform} · ${names.length} deps · ${ids.length} decisions detected</p>` +
        `<p class="meta">fit: <span class="mark-ok">${tally['✓']} aligned</span> · <span class="mark-warn">${tally['~']} contextual</span> · <span class="mark-dim">${tally['↗']} to review</span></p>`;
      html += '<div class="tbl"><table><thead><tr><th>decision</th><th>your choice</th><th>fit</th><th>the corpus says</th></tr></thead><tbody>';
      for (const id of ids) {
        const cap = caps[id]; if (!cap) continue;
        const f = fit(cap, [...byEntry[id].tokens]);
        const choice = [...byEntry[id].labels].join(', ');
        lines.push(`${f}  ${cap.slug}: ${choice}`);
        html += `<tr><td><a href="${BASE}entries/${cap.slug}/">${cap.slug}</a> <span class="badge ${cap.confidence}">${cap.confidence}</span></td>` +
          `<td>${esc(choice)}</td><td><span class="${f.startsWith('✓') ? 'mark-ok' : f.startsWith('~') ? 'mark-warn' : 'mark-dim'}">${f}</span></td>` +
          `<td class="muted">${esc(cap.def.slice(0, 160))}${cap.def.length > 160 ? '…' : ''}</td></tr>`;
      }
      html += '</tbody></table></div>';

      const expected = [...EXPECTED.always, ...(EXPECTED[platform] || [])];
      const gaps = expected.filter((id) => !byEntry[id] && caps[id]);
      if (gaps.length) {
        html += '<h2>Gaps</h2><p class="muted" style="font-size:.88rem">Expected domains with nothing detected — may be built-in or genuinely N/A for your architecture; verify.</p>';
        for (const id of gaps) {
          const cap = caps[id];
          lines.push(`GAP  ${cap.slug}: ${cap.def.slice(0, 100)}`);
          html += `<div class="card"><p style="margin:0"><a href="${BASE}entries/${cap.slug}/"><strong>${cap.slug}</strong></a>
            <span class="muted" style="font-size:.9rem"> — ${esc(cap.def.slice(0, 180))}${cap.def.length > 180 ? '…' : ''}</span></p></div>`;
        }
      }
      // ── migration plan: the CLI planner's per-entry rules, matched in-browser ──
      // (ports tools/detect.mjs minVer/verLt + react-brain-migrate.mjs matching)
      const minVer = (range) => { const m = String(range || '').match(/\d+(?:\.\d+){0,2}/); return m ? m[0].split('.').map(Number) : null; };
      const verLt = (a, b) => { for (let i = 0; i < 3; i++) { const x = a?.[i] || 0, y = b?.[i] || 0; if (x !== y) return x < y; } return false; };
      const globFind = (pat) => pat.endsWith('*') ? names.find((n) => n.startsWith(pat.slice(0, -1))) || null : (pat in deps ? pat : null);
      const steps = [];
      for (const r of migrations) {
        const name = globFind(r.pkg);
        if (!name) continue;
        if (r.below) { const iv = minVer(deps[name]); if (!iv || !verLt(iv, minVer(r.below))) continue; }
        let blocked = null;
        if (r.requires) {
          const reqName = globFind(r.requires.pkg);
          const rv = reqName ? minVer(deps[reqName]) : null;
          if (!rv || verLt(rv, minVer(r.requires.atleast))) blocked = `${r.requires.pkg} ≥ ${r.requires.atleast} (installed: ${reqName ? deps[reqName] : 'absent'})`;
        }
        steps.push({ ...r, name, installed: String(deps[name]), blocked });
      }
      const URANK = { dead: 0, deprecated: 1, superseded: 2, upgrade: 3, conditional: 4 };
      steps.sort((a, b) => (a.blocked ? 1 : 0) - (b.blocked ? 1 : 0) || URANK[a.urgency] - URANK[b.urgency]);
      if (steps.length) {
        html += '<h2>Migration plan</h2><p class="muted" style="font-size:.88rem">Installed versions crossed with the corpus\'s verified migration rules — sequenced, every step with receipts. Full plan incl. the legacy-API source scan: <code>npx react-brain migrate .</code></p>';
        for (const s of steps) {
          const glyph = s.urgency === 'dead' || s.urgency === 'deprecated' ? '✗' : '→';
          lines.push(`MIGRATE [${s.urgency}] ${s.name}@${s.installed} -> ${s.to}`);
          html += `<div class="card"><p style="margin:0"><span class="${s.urgency === 'dead' || s.urgency === 'deprecated' ? 'mark-warn' : 'mark-dim'}">${glyph}</span> <strong>${esc(s.name)}</strong><span class="meta"> ${esc(s.installed)}</span> → ${esc(s.to)}
            <span class="meta">[${s.urgency} · effort ${s.effort} · <a href="${BASE}entries/${s.slug}/">${s.slug}</a>]</span></p>
            <p class="muted" style="margin:.35rem 0 0; font-size:.88rem">${esc(s.why)}</p>` +
            (s.blocked ? `<p class="muted" style="margin:.35rem 0 0; font-size:.88rem">⛔ blocked by: ${esc(s.blocked)} — do that step first</p>` : '') +
            (s.receipts.length ? `<p class="meta" style="margin:.35rem 0 0">${s.receipts.slice(0, 2).map((u) => `<a href="${esc(u)}" rel="noopener">${esc(u.replace(/^https?:\/\/(www\.)?/, '').slice(0, 60))}</a>`).join(' · ')}</p>` : '') +
            '</div>';
        }
      }

      html += '<p class="muted" style="font-size:.88rem">✓ aligned = matches the recommendation for some context · ~ contextual = matches a when-clause · ↗ review = differs from the default (not necessarily wrong — check the entry\'s context keys). For modernization + source signals run <code>npx react-brain doctor .</code></p>';
      out.innerHTML = html;
      out.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      plainReport = lines.join('\n');
      document.getElementById('copy').hidden = false;
    });

    // the 30-second demo: a deliberately legacy RN app — dead CodePush, FlashList v1
    // blocked behind the RN gate, deprecated expo-av, an HTTP client with no cache
    document.getElementById('sample').addEventListener('click', () => {
      document.getElementById('pkg').value = JSON.stringify({
        name: 'legacy-rn-demo', version: '1.0.0',
        dependencies: {
          react: '18.3.1', 'react-native': '0.79.2', zustand: '5.0.0', axios: '^1.18.1',
          '@shopify/flash-list': '^1.7.1', 'react-native-code-push': '^8.2.1',
          'expo-av': '~13.10.0', 'react-native-vector-icons': '^10.0.3', typescript: '~5.5.4',
        },
      }, null, 2);
      document.getElementById('run').click();
    });

    document.getElementById('file').addEventListener('change', async (ev) => {
      const file = ev.target.files[0];
      if (!file) return;
      document.getElementById('pkg').value = await file.text();
      document.getElementById('run').click();
    });

    document.getElementById('copy').addEventListener('click', async (ev) => {
      await navigator.clipboard.writeText(plainReport);
      ev.target.textContent = 'Copied ✓';
      setTimeout(() => (ev.target.textContent = 'Copy report'), 1500);
    });
  </script>
</Base>
