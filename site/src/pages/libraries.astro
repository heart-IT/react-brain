---
import Base from '../layouts/Base.astro';
import { corpus, downloads, fmtDownloads, href } from '../lib/corpus.js';
const { entries } = corpus();
const dl = downloads();
// one row per concrete npm package the corpus tracks, joined to its owning entry
const rows = entries.flatMap((e) => (e.detect || [])
  .filter((d) => !d.pkg.includes('*'))
  .map((d) => ({ pkg: d.pkg, label: d.label, entry: e, weekly: dl[d.pkg] ?? null })));
rows.sort((a, b) => (b.weekly || 0) - (a.weekly || 0));
---
<Base title="react-brain — library browser">
  <h1>Library browser</h1>
  <p class="muted">Every concrete package the corpus tracks, joined to the decision it belongs to.
  Downloads are npm weekly figures from the corpus's last <code>signals</code> run — the same live
  check that keeps recommendations honest. A big number is popularity, <em>not</em> a verdict:
  click through to the entry for the context-keyed recommendation.</p>
  <div class="tbl"><table>
    <thead><tr><th>package</th><th>what the corpus calls it</th><th>decision</th><th>npm / week</th></tr></thead>
    <tbody>
      {rows.map((r) => (
        <tr>
          <td><code>{r.pkg}</code></td>
          <td>{r.label}</td>
          <td><a href={href(`entries/${r.entry.slug}/`)}>{r.entry.slug}</a> <span class={`badge ${r.entry.confidence}`}>{r.entry.confidence}</span></td>
          <td>{r.weekly != null ? fmtDownloads(r.weekly) : '—'}</td>
        </tr>
      ))}
    </tbody>
  </table></div>
</Base>
