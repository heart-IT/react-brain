---
import Base from '../../layouts/Base.astro';
import { corpus, track, href } from '../../lib/corpus.js';
const { groups, entries } = corpus();
const tr = track();
const fresh = (e) => e.updated && Date.now() - new Date(String(e.updated)).getTime() < 7 * 864e5;
---
<Base title="react-brain — decisions">
  <h1>Decisions</h1>
  <p class="muted prose">One page per decision. <span class="badge reviewed">reviewed</span> = checked against
  primary sources with a long-form explanation; <span class="badge drafted">drafted</span> = internally
  consistent, citable.</p>
  {groups.map((g) => (
    <section id={g.id}>
      <h2>{g.label}</h2>
      <div class="tbl"><table>
        <thead><tr><th>entry</th><th>topic</th><th>status</th><th>updated</th></tr></thead>
        <tbody>
          {g.entries.map((id) => {
            const e = entries.find((x) => x.id === id);
            return e && (
              <tr>
                <td><a href={href(`entries/${e.slug}/`)}>{e.slug}</a></td>
                <td>{e.topic}</td>
                <td><span class={`badge ${e.status}`}>{e.status}</span></td>
                <td class="meta">{String(e.updated)}{fresh(e) && <span class="mark-ok" title="re-verified this week" aria-label="re-verified this week"> ●</span>}</td>
              </tr>
            );
          })}
        </tbody>
      </table></div>
    </section>
  ))}
</Base>

<style>
  /* scanning hierarchy: the entry name leads, topic supports, status/updated recede */
  td:first-child a { font: 600 .92rem/1.5 var(--font-head); color: var(--bright); text-decoration: none; }
  td:first-child a:hover { color: var(--accent); }
  td:nth-child(2) { color: var(--muted); }
  td:nth-child(4) { white-space: nowrap; }
  /* mobile: entry + topic are the workflow; badges and dates return on the entry page */
  @media (max-width: 600px) {
    th:nth-child(n + 3), td:nth-child(n + 3) { display: none; }
  }
</style>
