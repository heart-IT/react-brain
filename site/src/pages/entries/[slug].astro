---
import Base from '../../layouts/Base.astro';
import { corpus, downloads, fmtDownloads, track, docHtml, href, GITHUB, census, revisions, scorecard } from '../../lib/corpus.js';

export function getStaticPaths() {
  return corpus().entries.map((e) => ({ params: { slug: e.slug }, props: { id: e.id } }));
}
const { id } = Astro.props;
const { entries, byId } = corpus();
const e = byId[id];
const dl = downloads();
const tr = track()[id];
const pkgs = (e.detect || []).filter((d) => !d.pkg.includes('*') && dl[d.pkg] != null);
const related = entries.filter((x) => x.group === e.group && x.id !== id);
const doc = docHtml(e);
// knowledge-graph edges: entries this one's own text cites (when-clauses, notes, tradeoffs)
const blobOf = (x) => [x.note, x.recommend?.default, ...(x.recommend?.when || []), ...(x.options || []).map((o) => o.tradeoff)].join(' ');
const refsOf = (x) => [...new Set([...String(blobOf(x)).matchAll(/RB-E-[A-Z0-9-]+/g)].map((m) => m[0]))].filter((r) => r !== x.id);
const refs = refsOf(e).filter((r) => byId[r]).map((r) => byId[r]);
// …and the reverse edges: every decision whose own text cites THIS one
const citedBy = entries.filter((x) => x.id !== id && refsOf(x).includes(id));
// calibration: what this confidence tier has actually earned on the public scorecard
const tier = scorecard()?.tiers?.[e.confidence];
// verification history: the dates this entry's file changed in git
const revs = revisions(id);
// per-option evidence: map option → detect label (fuzzy) → census adoption + npm downloads
const cen = census();
const agg = cen?.agg?.[id] || null;
const optEvidence = (e.options || []).map((o) => {
  const on = o.name.toLowerCase().replace(/\s*\(.*/, '');
  const d = (e.detect || []).find((x) => {
    const l = x.label.toLowerCase().replace(/\s*\(.*/, '');
    return l.length > 2 && (on.includes(l) || l.includes(on));
  });
  if (!d) return null;
  const ships = agg?.labels?.[d.label] ?? null;
  const wk = !d.pkg.includes('*') ? (dl[d.pkg] ?? null) : null;
  return ships != null || wk != null ? { ships, denom: agg?.denom ?? null, wk } : null;
});
const hasEvidence = optEvidence.some(Boolean);
// sources render as host › path labels — raw URLs overflow small screens and are
// miserable for screen readers; the full URL stays in href
const srcLabel = (u) => {
  try { const x = new URL(u); const p = x.pathname.replace(/\/$/, '');
    return x.hostname.replace(/^www\./, '') + (p.length > 36 ? p.slice(0, 35) + '\u2026' : p); }
  catch { return u; }
};
const toc = [
  ['options', 'Options'],
  e.migrate?.length ? ['migrate', 'Migration lines'] : null,
  e.note ? ['notes', 'Verified notes'] : null,
  e.reading?.length ? ['reading', 'Reading'] : null,
  e.watching?.length ? ['watching', 'Watching'] : null,
  e.sources?.length ? ['sources', 'Sources'] : null,
  doc ? ['explanation', 'Full explanation'] : null,
].filter(Boolean);
---
<Base title={`react-brain — ${e.slug}`} description={e.topic} activeGroup={e.group}>
  <p class="meta" style="margin-bottom:0"><span aria-hidden="true" style="color:var(--line-strong)">~/</span><a href={href('entries/')}>entries</a><span aria-hidden="true" style="color:var(--line-strong)">/</span><a href={href(`entries/#${e.group}`)} style="color:var(--muted)">{e.group}</a> · verified {String(e.updated)} · {(e.platforms || []).join(' + ')}</p>
  <h1>{e.topic}</h1>
  <p>
    <span class={`badge ${e.status}`}>{e.status}</span>
    <span class={`badge ${e.confidence}`}>confidence: {e.confidence}</span>
    {tr && <span class={`badge ${tr}`}>track: {tr}</span>}
    {tier?.score != null && (tier.resolved >= 3
      ? <a class="meta" href={href('scorecard/')} style="margin-left:.35rem">this tier holds {tier.score}% on the public scorecard ({tier.resolved}/{tier.total} graded · {tier.overturned} overturned) →</a>
      : <a class="meta" href={href('scorecard/')} style="margin-left:.35rem">early: {tier.resolved}/{tier.total} of this tier graded so far ({tier.overturned} overturned) — the public scorecard →</a>)}
  </p>
  {refs.length > 0 && (
    <p class="meta" style="margin:.2rem 0 0">related decisions: {refs.map((r, i) => (
      <>{i > 0 && ' · '}<a href={href(`entries/${r.slug}/`)}>{r.slug}</a></>
    ))}</p>
  )}
  {citedBy.length > 0 && (
    <p class="meta" style="margin:.2rem 0 0">cited by: {citedBy.map((r, i) => (
      <>{i > 0 && ' · '}<a href={href(`entries/${r.slug}/`)}>{r.slug}</a></>
    ))}</p>
  )}
  {revs.length > 1 && (
    <p class="meta" style="margin:.2rem 0 0">re-verified {revs.length}× — {revs.slice(0, 6).join(' · ')}{revs.length > 6 ? ` +${revs.length - 6}` : ''} · <a href={href('changelog/')}>changelog</a></p>
  )}

  <div id="session-banner" hidden class="card" style="padding:.6rem .9rem; margin:.6rem 0 0"></div>
  <nav aria-label="On this page" style="display:flex; flex-wrap:wrap; gap:.45rem; margin:.4rem 0 0">
    {toc.map(([id, label]) => (
      <a href={`#${id}`} class="meta" style="text-decoration:none">{label}</a>
    ))}
  </nav>

  <div class="card rec">
    <p class="label-caps" style="margin:0; color:var(--ok)">recommendation</p>
    <p style="margin:.4rem 0 0">{e.recommend?.default}</p>
    {e.recommend?.when?.length > 0 && (
      <ul class="muted" style="margin-top:.6rem">
        {e.recommend.when.map((w) => <li>{w}</li>)}
      </ul>
    )}
  </div>
  {e.confidence === 'low' && (
    <div class="card caution">
      <p style="margin:0" class="muted"><strong style="color:var(--warn)">Low confidence</strong> — fast-moving or lightly-vetted domain: treat the pick as a vetted lead and prototype before committing.</p>
    </div>
  )}

  <h2 id="options">Options &amp; tradeoffs</h2>
  <p class="meta" style="margin:-.35rem 0 .6rem">the field considered — and why each one isn’t the default here</p>
  <div class="tbl"><table>
    <thead><tr><th>option</th><th>tradeoff</th>{hasEvidence && <th>evidence</th>}</tr></thead>
    <tbody>{(e.options || []).map((o, i) => (
      <tr>
        <td><strong>{o.name}</strong></td><td>{o.tradeoff}</td>
        {hasEvidence && <td class="meta" style="white-space:nowrap">{optEvidence[i] ? [
          optEvidence[i].wk != null ? `${fmtDownloads(optEvidence[i].wk)}/wk` : null,
          optEvidence[i].ships != null ? `ships in ${optEvidence[i].ships}/${optEvidence[i].denom}` : null,
        ].filter(Boolean).join(' · ') : ''}</td>}
      </tr>
    ))}</tbody>
  </table></div>
  {hasEvidence && <p class="meta" style="margin:.35rem 0 0">evidence: npm weekly downloads (<a href={href('libraries/')}>signals snapshot</a>) · “ships in n/D” = adoption across the <a href={href('census/')}>production-app census</a>, honest denominators</p>}

  {e.migrate?.length > 0 && (
    <>
      <h2 id="migrate">Migration lines</h2>
      <p class="meta" style="margin:-.35rem 0 .6rem">version and deprecation lines this decision tracks — for YOUR repo's sequenced plan: <a href={href('doctor/')}>the doctor</a> or <code>npx react-brain migrate .</code></p>
      <div class="rows">
        {e.migrate.map((r) => (
          <div>
            <p style="margin:0"><strong>{r.from.pkg}{r.from.below ? ` < ${r.from.below}` : ''}</strong> → {r.to}
              <span class="meta"> [{r.urgency} · effort {r.effort}]</span></p>
            <p class="muted" style="margin:.3rem 0 0; font-size:.88rem; max-width:78ch">{r.why}</p>
            {r.receipts?.length > 0 && <p class="meta" style="margin:.25rem 0 0">{r.receipts.map((u, i) => (
              <>{i > 0 && ' · '}<a href={u} rel="noopener">{srcLabel(u)}</a></>
            ))}</p>}
          </div>
        ))}
      </div>
    </>
  )}

  {pkgs.length > 0 && (
    <p class="muted" style="font-size:.88rem">npm weekly downloads (from the corpus's last signals run): {pkgs.map((d, i) => <span>{i > 0 && ' · '}<code>{d.pkg}</code> {fmtDownloads(dl[d.pkg])}</span>)}
    </p>
  )}

  {e.note && (<><h2 id="notes">Verified notes</h2><p class="prose">{String(e.note).trim()}</p></>)}

  {e.reading?.length > 0 && (
    <>
      <h2 id="reading">Canonical reading</h2>
      <p class="muted" style="font-size:.88rem">Editorial annotations on why each piece matters — the
      articles themselves are the originals; read them there.</p>
      <div class="rows">
        {e.reading.map((r) => (
          <div>
            <a href={r.url} rel="noopener"><strong>{r.title}</strong></a>
            {r.by && <span class="meta" style="margin-left:.5rem">{r.by}</span>}
            <p style="margin:.3rem 0 0; font-size:.9rem; max-width:78ch" class="muted">{r.what}</p>
          </div>
        ))}
      </div>
    </>
  )}

  {e.watching?.length > 0 && (
    <>
      <h2 id="watching">Watching</h2>
      <p class="muted" style="font-size:.88rem">Curated talks, podcasts &amp; videos — the A/V companion to the reading list.</p>
      <div class="rows">
        {e.watching.map((w) => (
          <div>
            <a href={w.url} rel="noopener"><strong>{w.title}</strong></a>
            {w.by && <span class="meta" style="margin-left:.5rem">{w.by}</span>}
            <p style="margin:.3rem 0 0; font-size:.9rem; max-width:78ch" class="muted">{w.what}</p>
          </div>
        ))}
      </div>
    </>
  )}

  {e.sources?.length > 0 && (
    <>
      <h2 id="sources">Sources</h2>
      <ul>{e.sources.map((s) => <li><a href={s} rel="noopener">{srcLabel(s)}</a></li>)}</ul>
    </>
  )}
  {e.defer_to_skill && <p class="muted">Depth (in-domain rules) is owned by the <code>{e.defer_to_skill}</code> skill — this entry is selection breadth.</p>}

  {doc && (
    <>
      <h2 id="explanation">The full explanation</h2>
      <p class="muted" style="font-size:.88rem">The reviewed long-form essay behind this entry — the <em>why</em>, not a how-to. Also on <a href={`${GITHUB}/blob/main/encyclopedia/${e.doc}`} rel="noopener">GitHub</a>.</p>
      <article class="prose" set:html={doc} />
    </>
  )}

  {related.length > 0 && (
    <p class="muted">Related in {e.group}: {related.map((x, i) => <span>{i > 0 && ' · '}<a href={href(`entries/${x.slug}/`)}>{x.slug}</a></span>)}</p>
  )}

  <script is:inline define:vars={{ entryId: e.id, def: e.recommend?.default || '', when: e.recommend?.when || [] }}>
    // session context (set via the ⌘K console's `load`) personalizes this entry
    try {
      const ctx = JSON.parse(localStorage.getItem('rb-console-ctx'));
      const mine = ctx?.byEntry?.[entryId];
      if (mine) {
        const tokens = mine.tokens || [];
        const d = def.toLowerCase(), w = when.join('||').toLowerCase();
        const fit = tokens.some((x) => d.includes(x)) ? '✓ aligned' : tokens.some((x) => w.includes(x)) ? '~ contextual' : '↗ review';
        const cls = fit.startsWith('✓') ? 't-ok' : fit.startsWith('~') ? 't-warn' : 'muted';
        const el = document.getElementById('session-banner');
        el.innerHTML = `<span class="meta">~/${ctx.name}</span> · your choice here: <b>${mine.labels.join(', ').replace(/</g, '&lt;')}</b> — <span class="${cls}">${fit}</span>`;
        el.hidden = false;
      }
    } catch {}
  </script>
</Base>
