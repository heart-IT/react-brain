---
import Base from '../../layouts/Base.astro';
import { corpus, downloads, fmtDownloads, track, docHtml, href, GITHUB } from '../../lib/corpus.js';

export function getStaticPaths() {
  return corpus().entries.map((e) => ({ params: { slug: e.slug }, props: { id: e.id } }));
}
const { id } = Astro.props;
const { entries, byId } = corpus();
const e = byId[id];
const dl = downloads();
const tr = track()[id];
const pkgs = (e.detect || []).filter((d) => !d.pkg.includes('*') && dl[d.pkg] != null);
const related = entries.filter((x) => x.group === e.group && x.id !== id);
const doc = docHtml(e);
// sources render as host › path labels — raw URLs overflow small screens and are
// miserable for screen readers; the full URL stays in href
const srcLabel = (u) => {
  try { const x = new URL(u); const p = x.pathname.replace(/\/$/, '');
    return x.hostname.replace(/^www\./, '') + (p.length > 36 ? p.slice(0, 35) + '\u2026' : p); }
  catch { return u; }
};
const toc = [
  ['options', 'Options'],
  e.note ? ['notes', 'Verified notes'] : null,
  e.reading?.length ? ['reading', 'Reading'] : null,
  e.sources?.length ? ['sources', 'Sources'] : null,
  doc ? ['explanation', 'Full explanation'] : null,
].filter(Boolean);
---
<Base title={`react-brain — ${e.slug}`} description={e.topic} activeGroup={e.group}>
  <p class="meta" style="margin-bottom:0"><a href={href('entries/')}>entries</a> / <a href={href(`entries/#${e.group}`)} style="color:var(--muted)">{e.group}</a> · verified {String(e.updated)} · {(e.platforms || []).join(' + ')}</p>
  <h1>{e.topic}</h1>
  <p>
    <span class={`badge ${e.status}`}>{e.status}</span>
    <span class={`badge ${e.confidence}`}>confidence: {e.confidence}</span>
    {tr && <span class={`badge ${tr}`}>track: {tr}</span>}
  </p>

  <nav aria-label="On this page" style="display:flex; flex-wrap:wrap; gap:.45rem; margin:.4rem 0 0">
    {toc.map(([id, label]) => (
      <a href={`#${id}`} class="meta" style="text-decoration:none">{label}</a>
    ))}
  </nav>

  <div class="card rec">
    <p class="label-caps" style="margin:0; color:var(--ok)">recommendation</p>
    <p style="margin:.4rem 0 0">{e.recommend?.default}</p>
    {e.recommend?.when?.length > 0 && (
      <ul class="muted" style="margin-top:.6rem">
        {e.recommend.when.map((w) => <li>{w}</li>)}
      </ul>
    )}
  </div>
  {e.confidence === 'low' && (
    <div class="card caution">
      <p style="margin:0" class="muted"><strong style="color:var(--warn)">Low confidence</strong> — fast-moving or lightly-vetted domain: treat the pick as a vetted lead and prototype before committing.</p>
    </div>
  )}

  <h2 id="options">Options &amp; tradeoffs</h2>
  <div class="tbl"><table>
    <thead><tr><th>option</th><th>tradeoff</th></tr></thead>
    <tbody>{(e.options || []).map((o) => <tr><td><strong>{o.name}</strong></td><td>{o.tradeoff}</td></tr>)}</tbody>
  </table></div>

  {pkgs.length > 0 && (
    <p class="muted" style="font-size:.88rem">npm weekly downloads (from the corpus's last signals run):
      {pkgs.map((d, i) => <span>{i > 0 && ' · '}<code>{d.pkg}</code> {fmtDownloads(dl[d.pkg])}</span>)}
    </p>
  )}

  {e.note && (<><h2 id="notes">Verified notes</h2><p class="prose">{String(e.note).trim()}</p></>)}

  {e.reading?.length > 0 && (
    <>
      <h2 id="reading">Canonical reading</h2>
      <p class="muted" style="font-size:.88rem">Editorial annotations on why each piece matters — the
      articles themselves are the originals; read them there.</p>
      <div class="rows">
        {e.reading.map((r) => (
          <div>
            <a href={r.url} rel="noopener"><strong>{r.title}</strong></a>
            {r.by && <span class="meta" style="margin-left:.5rem">{r.by}</span>}
            <p style="margin:.3rem 0 0; font-size:.9rem; max-width:78ch" class="muted">{r.what}</p>
          </div>
        ))}
      </div>
    </>
  )}

  {e.sources?.length > 0 && (
    <>
      <h2 id="sources">Sources</h2>
      <ul>{e.sources.map((s) => <li><a href={s} rel="noopener">{srcLabel(s)}</a></li>)}</ul>
    </>
  )}
  {e.defer_to_skill && <p class="muted">Depth (in-domain rules) is owned by the <code>{e.defer_to_skill}</code> skill — this entry is selection breadth.</p>}

  {doc && (
    <>
      <h2 id="explanation">The full explanation</h2>
      <p class="muted" style="font-size:.88rem">The reviewed long-form essay behind this entry — the
      <em>why</em>, not a how-to. Also on <a href={`${GITHUB}/blob/main/encyclopedia/${e.doc}`} rel="noopener">GitHub</a>.</p>
      <article class="prose" set:html={doc} />
    </>
  )}

  {related.length > 0 && (
    <p class="muted">Related in {e.group}: {related.map((x, i) => <span>{i > 0 && ' · '}<a href={href(`entries/${x.slug}/`)}>{x.slug}</a></span>)}</p>
  )}
</Base>
