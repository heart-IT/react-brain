---
const { title = 'react-brain', description = 'A verified, context-keyed encyclopedia of the React + React Native ecosystem — what to use, when, and why.' } = Astro.props;
import { GITHUB } from '../lib/corpus.js';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
</head>
<body>
  <header>
    <nav>
      <a class="brand" href="/">🧠 react-brain</a>
      <a href="/entries/">entries</a>
      <a href="/libraries/">libraries</a>
      <a href="/reading/">reading</a>
      <a href="/scorecard/">scorecard</a>
      <a href="/doctor/">doctor</a>
      <a href={GITHUB} rel="noopener">github</a>
    </nav>
  </header>
  <main><slot /></main>
  <footer>
    <p>Generated from the <a href={GITHUB}>react-brain corpus</a> — every fact carries a
    verified-on date; every recommendation is context-keyed and adversarially challenged.
    Articles are cited and linked, never republished: read the originals.</p>
  </footer>
</body>
</html>

<style is:global>
  :root {
    --bg: #ffffff; --fg: #1a1d21; --muted: #5b6470; --line: #e4e7eb;
    --card: #f6f8fa; --accent: #2563eb; --ok: #157347; --warn: #b45309; --bad: #b3261e;
    color-scheme: light dark;
  }
  @media (prefers-color-scheme: dark) {
    :root { --bg: #101418; --fg: #e6e9ec; --muted: #98a2ad; --line: #2a3138; --card: #171d23; --accent: #7aa2ff; --ok: #4ade80; --warn: #fbbf24; --bad: #f87171; }
  }
  * { box-sizing: border-box; }
  body { margin: 0; background: var(--bg); color: var(--fg); font: 16px/1.6 ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif; }
  main { max-width: 60rem; margin: 0 auto; padding: 1.5rem 1.25rem 4rem; }
  header { border-bottom: 1px solid var(--line); }
  nav { max-width: 60rem; margin: 0 auto; padding: .8rem 1.25rem; display: flex; gap: 1.1rem; flex-wrap: wrap; align-items: baseline; }
  nav a { color: var(--muted); text-decoration: none; }
  nav a:hover { color: var(--fg); }
  nav .brand { color: var(--fg); font-weight: 700; margin-right: .5rem; }
  footer { border-top: 1px solid var(--line); color: var(--muted); font-size: .85rem; }
  footer p { max-width: 60rem; margin: 0 auto; padding: 1rem 1.25rem 2rem; }
  a { color: var(--accent); }
  h1 { font-size: 1.6rem; line-height: 1.25; margin: .5rem 0 .4rem; }
  h2 { font-size: 1.15rem; margin: 2rem 0 .5rem; }
  h3 { font-size: 1rem; margin: 1.2rem 0 .3rem; }
  table { border-collapse: collapse; width: 100%; font-size: .92rem; }
  th, td { text-align: left; padding: .45rem .6rem; border-bottom: 1px solid var(--line); vertical-align: top; }
  th { color: var(--muted); font-weight: 600; }
  code { background: var(--card); padding: .1em .35em; border-radius: 4px; font-size: .88em; }
  pre { background: var(--card); border: 1px solid var(--line); border-radius: 8px; padding: .9rem 1rem; overflow-x: auto; }
  .muted { color: var(--muted); }
  .card { background: var(--card); border: 1px solid var(--line); border-radius: 10px; padding: 1rem 1.1rem; margin: .8rem 0; }
  .badge { display: inline-block; font-size: .72rem; font-weight: 600; padding: .12em .55em; border-radius: 999px; border: 1px solid var(--line); color: var(--muted); vertical-align: middle; }
  .badge.reviewed { color: var(--ok); border-color: currentColor; }
  .badge.drafted { color: var(--warn); border-color: currentColor; }
  .badge.high { color: var(--ok); }
  .badge.medium { color: var(--warn); }
  .badge.low { color: var(--bad); }
  .badge.held { color: var(--ok); border-color: currentColor; }
  .badge.weakened { color: var(--warn); border-color: currentColor; }
  .badge.overturned { color: var(--bad); border-color: currentColor; }
  ul { padding-left: 1.2rem; }
  li { margin: .25rem 0; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr)); gap: .8rem; }
  .hero { padding: 1.5rem 0 .5rem; }
  .hero p { max-width: 44rem; }
  input, textarea, button { font: inherit; color: inherit; }
  textarea { width: 100%; min-height: 12rem; background: var(--card); border: 1px solid var(--line); border-radius: 8px; padding: .8rem; }
  button { background: var(--accent); color: #fff; border: 0; border-radius: 8px; padding: .55rem 1.1rem; cursor: pointer; font-weight: 600; }
</style>
