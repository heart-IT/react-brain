---
// "Technical Precision" theme — navigation shell synced to the v4 mock:
// top bar = brand · search field (⌘K) · doctor/libraries/reading/scorecard/github;
// left sidebar = the encyclopedia groups with entry counts (+ tools & meta pages at
// the bottom), active-group highlighted on entry pages. Dark-first tonal layers,
// Hanken Grotesk / Inter / JetBrains Mono, semantic color = categorization only.
const { title = 'react-brain', description = 'A verified, context-keyed encyclopedia of the React + React Native ecosystem — what to use, when, and why.', activeGroup = null } = Astro.props;
import { GITHUB, href, corpusInfo, corpus } from '../lib/corpus.js';
import interUrl from '../assets/fonts/Inter.woff2?url';
import hankenUrl from '../assets/fonts/HankenGrotesk.woff2?url';
import monoUrl from '../assets/fonts/JetBrainsMono.woff2?url';
const fontFaces = [
  ['Hanken Grotesk', hankenUrl, '100 900'],
  ['Inter', interUrl, '100 900'],
  ['JetBrains Mono', monoUrl, '100 800'],
].map(([fam, url, w]) => `@font-face{font-family:"${fam}";src:url(${url}) format("woff2");font-weight:${w};font-display:swap;}`).join('');
const info = corpusInfo();
const { groups } = corpus();
const path = Astro.url.pathname;
const FAVICON = "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧠</text></svg>";
const GLYPHS = {
  'react-foundations': 'M4 19V5a2 2 0 0 1 2-2h13v18H6a2 2 0 0 1-2-2zm0 0a2 2 0 0 1 2-2h13',
  'app-architecture': 'M12 3v6m0 0-6 6m6-6 6 6M4 21h4v-4H4zm12 0h4v-4h-4z',
  'ui': 'M12 3 3 8l9 5 9-5-9-5zm-9 9 9 5 9-5',
  'platform-native': 'M8 3h8a1 1 0 0 1 1 1v16a1 1 0 0 1-1 1H8a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zm3 15h2',
  'tooling-ops': 'M14 7a4 4 0 1 0-4 4L4 17l3 3 6-6a4 4 0 0 0 4-4c0-.6-.13-1.16-.36-1.67L14 11l-2-2 2.67-2.67A4 4 0 0 0 14 7z',
  'ai': 'M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3zm7 11 .9 2.6L22.5 17.5l-2.6.9L19 21l-.9-2.6-2.6-.9 2.6-.9L19 14z',
};
const bottomLinks = [
  { to: 'stack/', label: 'stack composer' },
  { to: 'architecture/', label: 'architecture' },
  { to: 'changelog/', label: 'changelog' },
  { to: 'methodology/', label: 'methodology' },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" href={FAVICON} />
  <link rel="preload" href={interUrl} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={hankenUrl} as="font" type="font/woff2" crossorigin />
  <style set:html={fontFaces}></style>
</head>
<body>
  <a class="skip" href="#main">Skip to content</a>
  <header>
    <div class="bar">
      <a class="brand" href={href('')}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="5" r="2.2" stroke="currentColor" stroke-width="1.6"/><circle cx="5" cy="16" r="2.2" stroke="currentColor" stroke-width="1.6"/><circle cx="19" cy="16" r="2.2" stroke="currentColor" stroke-width="1.6"/><path d="M10.8 6.8 6.2 14M13.2 6.8l4.6 7.2M7.2 16h9.6" stroke="currentColor" stroke-width="1.6"/></svg>
        react-brain
      </a>
      <form class="search" action={href('search/')} method="get" role="search">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <input id="nav-q" name="q" type="search" placeholder="Search packages, topics, or decisions…" autocomplete="off" aria-label="Search the encyclopedia" />
        <kbd>⌘K</kbd>
      </form>
      <nav aria-label="Primary">
        {[['doctor/', 'Doctor'], ['libraries/', 'Libraries'], ['reading/', 'Reading'], ['scorecard/', 'Scorecard']].map(([to, label]) => (
          <a href={href(to)} class={path.startsWith(href(to)) ? 'active' : ''} aria-current={path.startsWith(href(to)) ? 'page' : undefined}>{label}</a>
        ))}
        <a href={GITHUB} rel="noopener">GitHub</a>
      </nav>
    </div>
  </header>

  <details class="mobile-nav">
    <summary>Browse documentation</summary>
    <div class="mobile-nav-items">
      {groups.map((g) => (
        <a href={href(`entries/#${g.id}`)}>{g.label.split(' — ')[0].split(' (')[0]} <span class="count">{g.entries.length}</span></a>
      ))}
      {bottomLinks.map((l) => <a href={href(l.to)}>{l.label}</a>)}
      <a href={href('stack/')} hidden></a>
    </div>
  </details>

  <div class="shell">
    <aside aria-label="Documentation">
      <p class="label-caps side-head">Documentation</p>
      <p class="meta" style="margin:.1rem 0 .9rem">React ecosystem · corpus v{info.version}</p>
      {groups.map((g) => (
        <a class={`side-item${activeGroup === g.id ? ' active' : ''}`} aria-current={activeGroup === g.id ? 'location' : undefined} href={href(`entries/#${g.id}`)}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d={GLYPHS[g.id]} stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" stroke-linecap="round"/></svg>
          <span>{g.label.split(' — ')[0].split(' (')[0]}</span>
          <span class="count">{g.entries.length}</span>
        </a>
      ))}
      <div class="side-bottom">
        {bottomLinks.map((l) => (
          <a class={`side-item${path.startsWith(href(l.to)) ? ' active' : ''}`} aria-current={path.startsWith(href(l.to)) ? 'page' : undefined} href={href(l.to)}>
            <span>{l.label}</span>
          </a>
        ))}
      </div>
    </aside>

    <div class="content">
      <main id="main"><slot /></main>
      <footer>
        <p class="meta" style="display:flex; gap:.6rem; flex-wrap:wrap; align-items:center">
          <span>corpus v{info.version}</span>·<span>{info.count} decisions</span>·<span>last updated {info.updated}</span>
          <span style="margin-left:auto"><a href={href('changelog/')} style="color:var(--muted)">changelog →</a></span>
        </p>
        <p>Generated from the <a href={GITHUB}>react-brain corpus</a> — every fact carries a
        verified-on date; every recommendation is context-keyed and adversarially challenged
        (<a href={href('methodology/')}>methodology</a>). Articles are cited and linked, never
        republished: read the originals.</p>
      </footer>
    </div>
  </div>

  <script is:inline>
    // DESIGN.md: "Code Blocks: … with a Copy action in the top right"
    for (const pre of document.querySelectorAll('pre')) {
      const text = pre.innerText;
      const b = document.createElement('button');
      b.type = 'button'; b.className = 'copy-btn'; b.textContent = 'copy';
      b.setAttribute('aria-label', 'Copy code to clipboard');
      b.addEventListener('click', async () => {
        try { await navigator.clipboard.writeText(text); b.textContent = '✓'; }
        catch { b.textContent = '✗'; }
        setTimeout(() => (b.textContent = 'copy'), 1400);
      });
      pre.appendChild(b);
    }
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        const q = document.getElementById('nav-q');
        if (q) q.focus();
      }
    });
  </script>
</body>
</html>

<style is:global>
  :root {
    /* Technical Precision tokens (technical_precision/DESIGN.md) */
    --bg: #0F1115;            /* base layer */
    --card: #161B22;          /* content layer */
    --code-bg: #010409;       /* code blocks — distinct from cards */
    --line: #30363D;          /* border-subtle */
    --line-strong: #3F484E;   /* outline-variant / hover borders */
    --fg: #E2E2E8;            /* on-surface */
    --bright: #FFFFFF;
    --muted: #94A3B8;         /* text-muted */
    --accent: #38BDF8;        /* link-blue: actions + hyperlinks */
    --primary: #79D1FB;       /* primary buttons */
    --on-primary: #003547;
    --ok: #22C55E;            /* recommended */
    --warn: #F59E0B;          /* caveat */
    --bad: #EF4444;           /* avoid / deprecated */
    --exp: #A855F7;           /* experimental */
    --font-head: "Hanken Grotesk", ui-sans-serif, system-ui, sans-serif;
    --font-body: "Inter", ui-sans-serif, system-ui, sans-serif;
    --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    --header-h: 56px;
    color-scheme: dark;       /* dark-first by design */
  }
  * { box-sizing: border-box; }
  body { margin: 0; background: var(--bg); color: var(--fg); font: 400 15.5px/1.6 var(--font-body); }

  /* ── top bar ─────────────────────────────────────────────────────────────── */
  header { border-bottom: 1px solid var(--line); background: color-mix(in srgb, var(--bg) 92%, black); position: sticky; top: 0; z-index: 5; }
  .bar { max-width: 1500px; margin: 0 auto; padding: 0 20px; height: var(--header-h); display: flex; gap: 1.1rem; align-items: center; }
  .brand { color: var(--bright); font: 700 1.05rem var(--font-head); display: inline-flex; align-items: center; gap: .45rem; text-decoration: none; white-space: nowrap; }
  .brand svg { color: var(--accent); }
  .search { flex: 1 1 200px; max-width: 430px; display: flex; align-items: center; gap: .5rem; background: var(--card); border: 1px solid var(--line); border-radius: 8px; padding: .38rem .7rem; color: var(--muted); }
  .search:focus-within { border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 30%, transparent); }
  .search input { flex: 1; min-width: 0; background: none; border: 0; color: var(--fg); font-size: .9rem; }
  .search input:focus { outline: none; box-shadow: none; border: 0; }
  .search kbd { font: 500 .7rem var(--font-mono); color: var(--muted); background: var(--bg); border: 1px solid var(--line); border-radius: 4px; padding: .1em .4em; }
  header nav { margin-left: auto; display: flex; gap: 1.05rem; align-items: center; }
  header nav a { color: var(--muted); text-decoration: none; font-size: .92rem; font-weight: 500; white-space: nowrap; padding: .95rem .15rem; }
  header nav a:hover { color: var(--fg); }
  header nav a.active { color: var(--bright); box-shadow: inset 0 -2px 0 var(--accent); }

  /* ── shell: sidebar + content ────────────────────────────────────────────── */
  .shell { max-width: 1500px; margin: 0 auto; display: grid; grid-template-columns: 250px minmax(0, 1fr); }
  aside { border-right: 1px solid var(--line); padding: 1.1rem .9rem 1.1rem 20px; position: sticky; top: var(--header-h); height: calc(100vh - var(--header-h)); overflow-y: auto; display: flex; flex-direction: column; }
  .side-head { color: var(--muted); margin: 0; }
  .side-item { display: flex; align-items: center; gap: .55rem; color: var(--muted); text-decoration: none; font-size: .9rem; font-weight: 500; padding: .6rem .55rem; border-radius: 4px; border-left: 2px solid transparent; }
  .side-item:hover { color: var(--fg); background: var(--card); }
  .side-item.active { color: var(--bright); background: var(--card); border-left-color: var(--accent); }
  .side-item .count { margin-left: auto; font: 500 .72rem var(--font-mono); color: var(--muted); background: var(--bg); border: 1px solid var(--line); border-radius: 4px; padding: .05em .45em; }
  .side-bottom { margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--line); }
  .content main { max-width: 1200px; margin: 0 auto; padding: 1.5rem 24px 4rem; }
  footer { border-top: 1px solid var(--line); color: var(--muted); font-size: .85rem; }
  footer p { max-width: 1200px; margin: 0 auto; padding: 1rem 24px 2rem; }
  footer p.meta { padding-bottom: 0; }
  .mobile-nav { display: none; border-bottom: 1px solid var(--line); }
  .mobile-nav summary { cursor: pointer; padding: .7rem 20px; font: 600 .78rem/1.4 var(--font-body); text-transform: uppercase; letter-spacing: .05em; color: var(--muted); list-style: none; }
  .mobile-nav summary::before { content: '☰  '; }
  .mobile-nav[open] summary { color: var(--fg); }
  .mobile-nav-items { display: flex; flex-wrap: wrap; gap: .4rem .8rem; padding: 0 20px .9rem; }
  .mobile-nav-items a { color: var(--muted); text-decoration: none; font-size: .9rem; padding: .45rem .6rem; background: var(--card); border: 1px solid var(--line); border-radius: 4px; }
  .mobile-nav-items a .count { color: var(--muted); font: 500 .72rem var(--font-mono); }
  @media (max-width: 1023px) {
    aside { display: none; }
    .mobile-nav { display: block; }
    .shell { grid-template-columns: minmax(0, 1fr); }
    .search kbd { display: none; }
    header nav { gap: .8rem; }
  }
  @media (max-width: 640px) { .search { display: none; } }

  a { color: var(--accent); text-decoration-thickness: 1px; text-underline-offset: 2px; }
  :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 3px; }
  .skip { position: absolute; left: -999px; top: 0; background: var(--accent); color: #00263a; padding: .5rem 1rem; z-index: 10; }
  .skip:focus { left: .5rem; top: .5rem; }

  /* typography scale — headline-xl/lg/md from the design spec */
  h1, h2, h3 { font-family: var(--font-head); color: var(--bright); }
  h1 { font-size: clamp(1.75rem, 1.1rem + 2.4vw, 3rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.17; margin: .5rem 0 .4rem; }
  h2 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.01em; margin: 2.2rem 0 .6rem; }
  h3 { font-size: 1.1rem; font-weight: 600; margin: 1.3rem 0 .35rem; }
  .label-caps, th, legend { font: 600 .75rem/1.35 var(--font-body); text-transform: uppercase; letter-spacing: .05em; }
  .meta { font: 400 .8rem/1.5 var(--font-mono); color: var(--muted); }

  /* code — literal values are mono; blocks sit on the deepest layer */
  code { background: var(--card); border: 1px solid var(--line); padding: .08em .35em; border-radius: 4px; font: 400 .82em var(--font-mono); }
  pre { background: var(--code-bg); border: 1px solid var(--line); border-radius: 8px; padding: .9rem 1rem; overflow-x: auto; font: 400 13px/1.55 var(--font-mono); position: relative; }
  .copy-btn { position: absolute; top: .45rem; right: .45rem; background: var(--card); color: var(--muted); border: 1px solid var(--line); border-radius: 4px; padding: .12rem .5rem; font: 500 .72rem var(--font-mono); opacity: 0; }
  pre:hover .copy-btn, .copy-btn:focus-visible { opacity: 1; }
  @media (hover: none) { .copy-btn { opacity: 1; } }
  pre code { background: none; border: 0; padding: 0; }
  blockquote { border-left: 3px solid var(--line-strong); margin: 1rem 0; padding: .1rem 1rem; color: var(--muted); }

  /* tables — label-caps headers, subtle rows */
  .tbl { overflow-x: auto; }
  table { border-collapse: collapse; width: 100%; font-size: .9rem; }
  th, td { text-align: left; padding: .5rem .65rem; border-bottom: 1px solid var(--line); vertical-align: top; }
  th { color: var(--muted); }
  tbody tr:hover { background: color-mix(in srgb, var(--card) 55%, transparent); }

  .muted { color: var(--muted); }
  .card { background: var(--card); border: 1px solid var(--line); border-radius: 8px; padding: 1rem 1.1rem; margin: .8rem 0; transition: border-color .15s; }
  .card:hover { border-color: var(--line-strong); }
  /* callouts: left color bar, per the functional palette */
  .card.rec { border-left: 3px solid var(--ok); }
  .card.caution { border-left: 3px solid var(--warn); }

  /* chips: high-contrast text on ~10% tinted background (never pills-with-borders) */
  .badge { display: inline-block; font: 600 .75rem/1.4 var(--font-body); text-transform: uppercase; letter-spacing: .05em; padding: .14em .55em; border-radius: 4px; color: var(--muted); background: color-mix(in srgb, var(--muted) 12%, transparent); vertical-align: middle; }
  .badge.reviewed, .badge.high, .badge.held { color: var(--ok); background: color-mix(in srgb, var(--ok) 12%, transparent); }
  .badge.drafted, .badge.medium, .badge.weakened { color: var(--warn); background: color-mix(in srgb, var(--warn) 12%, transparent); }
  .badge.low, .badge.overturned { color: var(--bad); background: color-mix(in srgb, var(--bad) 12%, transparent); }
  .badge.stub, .badge.beta { color: var(--exp); background: color-mix(in srgb, var(--exp) 12%, transparent); }

  ul { padding-left: 1.2rem; }
  li { margin: .25rem 0; }
  .hero { padding: 1.6rem 0 .5rem; }
  .hero p { max-width: 46rem; font-size: 1.06rem; }

  /* stat tiles — interactive: hover reveals the action */
  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(9.5rem, 1fr)); gap: .8rem; margin: 1.2rem 0; }
  .stat { display: block; background: var(--card); border: 1px solid var(--line); border-radius: 8px; padding: .8rem 1rem; text-decoration: none; position: relative; transition: border-color .15s; }
  .stat .label { font: 500 .74rem var(--font-mono); color: var(--muted); letter-spacing: .03em; }
  .stat .value { font: 700 1.7rem/1.2 var(--font-head); color: var(--bright); margin-top: .15rem; }
  .stat .go { position: absolute; right: .8rem; bottom: .6rem; font: 600 .74rem var(--font-body); color: var(--accent); opacity: 0; transform: translateX(-4px); transition: opacity .15s, transform .15s; }
  .stat:hover, .stat:focus-visible { border-color: var(--accent); }
  .stat:hover .go, .stat:focus-visible .go { opacity: 1; transform: none; }

  /* the flagship sidebar widget — visually distinct from ordinary cards */
  .card.pick { border-color: color-mix(in srgb, var(--accent) 45%, var(--line)); background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 7%, var(--card)), var(--card)); }
  .card.pick:hover { border-color: var(--accent); }

  /* buttons — primary solid, secondary ghost; rectangular soft corners, never pills */
  input, textarea, button, select { font: inherit; color: inherit; }
  button, .btn { display: inline-block; background: var(--primary); color: var(--on-primary); border: 1px solid transparent; border-radius: 4px; padding: .55rem 1.1rem; cursor: pointer; font-weight: 600; text-decoration: none; }
  button:hover, .btn:hover { background: color-mix(in srgb, var(--primary) 88%, white); }
  .btn.ghost, button.ghost { background: transparent; color: var(--fg); border-color: var(--line-strong); }
  .btn.ghost:hover, button.ghost:hover { border-color: var(--muted); background: var(--card); }
  textarea { width: 100%; min-height: 12rem; background: var(--code-bg); border: 1px solid var(--line); border-radius: 8px; padding: .8rem; font: 400 13px/1.55 var(--font-mono); }
  select { background: var(--card); border: 1px solid var(--line); border-radius: 4px; padding: .4rem .6rem; }
  textarea:focus, select:focus, input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 35%, transparent); }
  fieldset { border: 1px solid var(--line); border-radius: 8px; padding: .8rem 1rem; margin: .8rem 0; }
  legend { color: var(--muted); padding: 0 .4rem; }
  label { margin-right: 1rem; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr)); gap: .8rem; }
  .prose { max-width: 46rem; }
  .prose h1 { font-size: 1.5rem; margin-top: 1.8rem; }
  .prose h2 { font-size: 1.25rem; margin-top: 1.8rem; }
  .prose h3 { font-size: 1.05rem; }
  .prose img { max-width: 100%; border-radius: 8px; }
  .prose h4 { font-size: .95rem; }
  .card p, .card ul { max-width: 78ch; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { transition-duration: .01ms !important; animation-duration: .01ms !important; }
    html { scroll-behavior: auto !important; }
  }
</style>
