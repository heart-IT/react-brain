---
// "Technical Precision" theme — navigation shell synced to the v4 mock:
// top bar = brand · search field (⌘K) · doctor/libraries/reading/scorecard/github;
// left sidebar = the encyclopedia groups with entry counts (+ tools & meta pages at
// the bottom), active-group highlighted on entry pages. Dark-first tonal layers,
// Hanken Grotesk / Inter / JetBrains Mono, semantic color = categorization only.
const { title = 'react-brain', description = 'A verified, context-keyed encyclopedia of the React + React Native ecosystem — what to use, when, and why.', activeGroup = null } = Astro.props;
import { GITHUB, href, corpusInfo, corpus } from '../lib/corpus.js';
import interUrl from '../assets/fonts/Inter.woff2?url';
import monoUrl from '../assets/fonts/JetBrainsMono.woff2?url';
const fontFaces = [
  ['Inter', interUrl, '100 900'],
  ['JetBrains Mono', monoUrl, '100 800'],
].map(([fam, url, w]) => `@font-face{font-family:"${fam}";src:url(${url}) format("woff2");font-weight:${w};font-display:swap;}`).join('');
const info = corpusInfo();
const { groups } = corpus();
const path = Astro.url.pathname;
const FAVICON = "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧠</text></svg>";
const bottomLinks = [
  { to: 'stack/', label: 'stack composer' },
  { to: 'architecture/', label: 'architecture' },
  { to: 'changelog/', label: 'changelog' },
  { to: 'methodology/', label: 'methodology' },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" href={FAVICON} />
  <link rel="preload" href={interUrl} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={monoUrl} as="font" type="font/woff2" crossorigin />
  <style set:html={fontFaces}></style>
</head>
<body>
  <a class="skip" href="#main">Skip to content</a>
  <header>
    <div class="bar">
      <a class="brand" href={href('')}><span aria-hidden="true" class="prompt">❯</span> react-brain</a>
      <form class="search" action={href('search/')} method="get" role="search">
        <span aria-hidden="true" class="prompt">❯</span>
        <input id="nav-q" name="q" type="search" placeholder="search the corpus…" autocomplete="off" aria-label="Search the encyclopedia" />
        <kbd>⌘K</kbd>
      </form>
      <nav aria-label="Primary">
        <a class="search-link" href={href('search/')}>search</a>
        {[['doctor/', 'Doctor'], ['libraries/', 'Libraries'], ['reading/', 'Reading'], ['scorecard/', 'Scorecard']].map(([to, label]) => (
          <a href={href(to)} class={path.startsWith(href(to)) ? 'active' : ''} aria-current={path.startsWith(href(to)) ? 'page' : undefined}>{label}</a>
        ))}
        <a href={GITHUB} rel="noopener">GitHub</a>
      </nav>
    </div>
  </header>

  <details class="mobile-nav">
    <summary>Browse documentation</summary>
    <div class="mobile-nav-items">
      {groups.map((g) => (
        <a href={href(`entries/#${g.id}`)}>{g.label.split(' — ')[0].split(' (')[0]} <span class="count">{g.entries.length}</span></a>
      ))}
      {bottomLinks.map((l) => <a href={href(l.to)}>{l.label}</a>)}
      <a href={href('stack/')} hidden></a>
    </div>
  </details>

  <div class="shell">
    <aside aria-label="Documentation">
      <p class="label-caps side-head">Documentation</p>
      <p class="meta" style="margin:.1rem 0 .9rem">React ecosystem · corpus v{info.version}</p>
      {groups.map((g) => (
        <a class={`side-item${activeGroup === g.id ? ' active' : ''}`} aria-current={activeGroup === g.id ? 'location' : undefined} href={href(`entries/#${g.id}`)}>
          <span aria-hidden="true" class="tree">▸</span>
          <span>{g.label.split(' — ')[0].split(' (')[0].toLowerCase()}/</span>
          <span class="count">{g.entries.length}</span>
        </a>
      ))}
      <div class="side-bottom">
        {bottomLinks.map((l) => (
          <a class={`side-item${path.startsWith(href(l.to)) ? ' active' : ''}`} aria-current={path.startsWith(href(l.to)) ? 'page' : undefined} href={href(l.to)}>
            <span>{l.label}</span>
          </a>
        ))}
      </div>
    </aside>

    <div class="content">
      <main id="main"><slot /></main>
      <footer>
        <p class="statusline" aria-label="Corpus status">
          <span class="mode">corpus v{info.version}</span>
          <span>{info.count} decisions</span><span>·</span><span>updated {info.updated}</span>
          <span style="margin-left:auto"><a href={href('changelog/')} style="color:var(--muted)">changelog →</a></span>
        </p>
        <p>Generated from the <a href={GITHUB}>react-brain corpus</a> — every fact carries a
        verified-on date; every recommendation is context-keyed and adversarially challenged
        (<a href={href('methodology/')}>methodology</a>). Articles are cited and linked, never
        republished: read the originals.</p>
      </footer>
    </div>
  </div>

  <script is:inline>
    // DESIGN.md: "Code Blocks: … with a Copy action in the top right"
    for (const pre of document.querySelectorAll('pre')) {
      const text = pre.innerText;
      const b = document.createElement('button');
      b.type = 'button'; b.className = 'copy-btn'; b.textContent = 'copy';
      b.setAttribute('aria-label', 'Copy code to clipboard');
      b.addEventListener('click', async () => {
        try { await navigator.clipboard.writeText(text); b.textContent = '✓'; }
        catch { b.textContent = '✗'; }
        setTimeout(() => (b.textContent = 'copy'), 1400);
      });
      pre.appendChild(b);
    }
    // honest shortcut hint per platform (Ctrl+K works everywhere; the glyph is Mac-only)
    if (!/Mac|iPhone|iPad/.test(navigator.platform)) {
      const k = document.querySelector('.search kbd');
      if (k) k.textContent = 'Ctrl K';
    }
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        const q = document.getElementById('nav-q');
        if (q) q.focus();
      }
    });
  </script>
</body>
</html>

<style is:global>
  :root {
    /* "phosphor" — terminal-native palette (ANSI-derived, true black). The
       product is a CLI; the site dresses like its habitat. Mono is the UI voice;
       Inter stays for long-form prose only. */
    --bg: #0A0A0A;            /* terminal black */
    --card: #121312;          /* panel */
    --code-bg: #0E0F0E;       /* code panel */
    --line: #1F221F;          /* hairlines */
    --line-strong: #313530;
    --fg: #D4D8D4;            /* body */
    --bright: #F2F5F2;        /* headings / emphasis */
    --muted: #8B948C;
    --accent: #50FA7B;        /* phosphor green: prompts, links, active, ✓ */
    --primary: #50FA7B;       /* primary action = green key */
    --on-primary: #0A0A0A;
    --ok: #50FA7B;            /* ANSI green */
    --warn: #E7C664;          /* ANSI yellow */
    --bad: #FF7B72;           /* ANSI red */
    --exp: #BD93F9;           /* ANSI magenta */
    --font-head: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    --font-body: "Inter", ui-sans-serif, system-ui, sans-serif;
    --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    --header-h: 56px;
    color-scheme: dark;       /* dark-first by design */
  }
  * { box-sizing: border-box; }
  body { margin: 0; background: var(--bg); color: var(--fg); font: 400 16px/1.65 var(--font-body); }
  body::before { content: ""; position: fixed; inset: 0; z-index: -1; pointer-events: none;
    background:
      radial-gradient(55% 38% at 62% -6%, rgba(80, 250, 123, .07), transparent 65%),
      radial-gradient(40% 30% at 8% 12%, rgba(80, 250, 123, .03), transparent 60%); }

  /* ── top bar ─────────────────────────────────────────────────────────────── */
  header { border-bottom: 1px solid var(--line); background: color-mix(in srgb, var(--bg) 88%, transparent); backdrop-filter: blur(8px); position: sticky; top: 0; z-index: 5; }
  .bar { max-width: 1500px; margin: 0 auto; padding: 0 20px; height: var(--header-h); display: flex; gap: 1.1rem; align-items: center; }
  .brand { color: var(--bright); font: 700 .95rem var(--font-mono); display: inline-flex; align-items: center; gap: .4rem; text-decoration: none; white-space: nowrap; }
  .prompt { color: var(--accent); font-family: var(--font-mono); font-weight: 700; }
  .search { flex: 1 1 200px; max-width: 430px; display: flex; align-items: center; gap: .55rem; background: var(--code-bg); border: 1px solid var(--line); border-radius: 4px; padding: .38rem .7rem; color: var(--muted); }
  .search:focus-within { border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 30%, transparent); }
  .search input { flex: 1; min-width: 0; background: none; border: 0; color: var(--fg); font: 400 .85rem var(--font-mono); }
  .search input:focus { outline: none; box-shadow: none; border: 0; }
  .search kbd { font: 500 .7rem var(--font-mono); color: var(--muted); background: var(--bg); border: 1px solid var(--line); border-radius: 4px; padding: .1em .4em; }
  header nav { margin-left: auto; display: flex; gap: 1.05rem; align-items: center; }
  header nav a { color: var(--muted); text-decoration: none; font: 500 .85rem var(--font-mono); white-space: nowrap; padding: .95rem .15rem; }
  header nav a:hover { color: var(--fg); }
  header nav a.active { color: var(--accent); box-shadow: inset 0 -1px 0 var(--accent); }

  /* ── shell: sidebar + content ────────────────────────────────────────────── */
  .shell { max-width: 1500px; margin: 0 auto; display: grid; grid-template-columns: 250px minmax(0, 1fr); }
  aside { border-right: 1px solid var(--line); padding: 1.1rem .9rem 1.1rem 20px; position: sticky; top: var(--header-h); height: calc(100vh - var(--header-h)); overflow-y: auto; display: flex; flex-direction: column; }
  .side-head { color: var(--muted); margin: 0; }
  .side-item { display: flex; align-items: center; gap: .5rem; color: var(--muted); text-decoration: none; font: 400 .85rem var(--font-mono); padding: .6rem .55rem; border-radius: 4px; border-left: 2px solid transparent; }
  .side-item:hover { color: var(--fg); background: var(--card); }
  .side-item.active { color: var(--accent); background: var(--card); border-left-color: var(--accent); }
  .side-item .tree { color: var(--line-strong); }
  .side-item.active .tree { color: var(--accent); }
  .side-item .count { margin-left: auto; font: 400 .75rem var(--font-mono); color: var(--muted); opacity: .75; }
  .side-bottom { margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--line); }
  .content main { max-width: 1140px; margin: 0 auto; padding: 2.4rem 28px 5rem; }
  footer { border-top: 1px solid var(--line); color: var(--muted); font-size: .85rem; }
  footer p { max-width: 1200px; margin: 0 auto; padding: 1rem 24px 2rem; }
  footer p.meta { padding-bottom: 0; }
  .mobile-nav { display: none; border-bottom: 1px solid var(--line); }
  .mobile-nav summary { cursor: pointer; padding: .7rem 20px; font: 600 .78rem/1.4 var(--font-body); text-transform: uppercase; letter-spacing: .05em; color: var(--muted); list-style: none; }
  .mobile-nav summary::before { content: '☰  '; }
  .mobile-nav[open] summary { color: var(--fg); }
  .mobile-nav-items { display: flex; flex-wrap: wrap; gap: .4rem .8rem; padding: 0 20px .9rem; }
  .mobile-nav-items a { color: var(--muted); text-decoration: none; font-size: .9rem; padding: .45rem .6rem; background: var(--card); border: 1px solid var(--line); border-radius: 4px; }
  .mobile-nav-items a .count { color: var(--muted); font: 500 .72rem var(--font-mono); }
  @media (max-width: 1023px) {
    aside { display: none; }
    .mobile-nav { display: block; }
    .shell { grid-template-columns: minmax(0, 1fr); }
    .search kbd { display: none; }
    header nav { gap: .8rem; }
  }
  .search-link { display: none !important; }
  @media (max-width: 640px) {
    .search { display: none; }
    .search-link { display: inline !important; }
  }

  a { color: var(--accent); text-decoration-thickness: 1px; text-underline-offset: 2px; }
  :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; border-radius: 3px; }
  .skip { position: absolute; left: -999px; top: 0; background: var(--accent); color: #00263a; padding: .5rem 1rem; z-index: 10; }
  .skip:focus { left: .5rem; top: .5rem; }

  /* typography scale — headline-xl/lg/md from the design spec */
  h1, h2, h3 { font-family: var(--font-head); color: var(--bright); }
  h1 { font-size: clamp(1.6rem, 1rem + 2.4vw, 2.7rem); font-weight: 700; letter-spacing: -0.035em; line-height: 1.18; margin: .5rem 0 .4rem;
    background: linear-gradient(180deg, #FCFEFC 55%, #99A39B); -webkit-background-clip: text; background-clip: text; color: transparent; }
  h2 { font-size: 1.05rem; font-weight: 600; letter-spacing: -0.01em; margin: 3.2rem 0 .9rem; }
  main h2::before { content: "# " / ""; color: var(--accent); font-weight: 400; }
  h3 { font-size: .95rem; font-weight: 600; margin: 1.3rem 0 .35rem; }
  .label-caps, th, legend { font: 500 .78rem/1.5 var(--font-mono); text-transform: none; letter-spacing: 0; color: var(--muted); }
  .meta { font: 400 .8rem/1.5 var(--font-mono); color: var(--muted); }

  /* code — literal values are mono; blocks sit on the deepest layer */
  code { background: var(--card); border: 1px solid var(--line); padding: .08em .35em; border-radius: 4px; font: 400 .82em var(--font-mono); }
  pre { background: var(--code-bg); border: 1px solid var(--line); border-radius: 8px; padding: .9rem 1rem; overflow-x: auto; font: 400 13px/1.55 var(--font-mono); position: relative; }
  .copy-btn { position: absolute; top: .45rem; right: .45rem; background: var(--card); color: var(--muted); border: 1px solid var(--line); border-radius: 4px; padding: .12rem .5rem; font: 500 .72rem var(--font-mono); opacity: 0; }
  pre:hover .copy-btn, .copy-btn:focus-visible { opacity: 1; }
  @media (hover: none) { .copy-btn { opacity: 1; } }
  pre code { background: none; border: 0; padding: 0; }
  blockquote { border-left: 3px solid var(--line-strong); margin: 1rem 0; padding: .1rem 1rem; color: var(--muted); }

  /* tables — label-caps headers, subtle rows */
  .tbl { overflow-x: auto; }
  table { border-collapse: collapse; width: 100%; font-size: .9rem; }
  th, td { text-align: left; padding: .6rem .7rem .6rem 0; border-bottom: 1px solid var(--line); vertical-align: top; }
  th { color: var(--muted); }
  tbody tr:hover { background: color-mix(in srgb, var(--card) 45%, transparent); }

  .muted { color: var(--muted); }
  .card { background: linear-gradient(180deg, color-mix(in srgb, var(--card) 92%, white), var(--card)); border-radius: 10px; padding: 1.1rem 1.25rem; margin: 1rem 0;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.05), 0 12px 32px -20px rgba(0,0,0,.9); }
  a.card { transition: transform .16s ease-out, box-shadow .16s ease-out; }
  a.card:hover { transform: translateY(-2px); box-shadow: inset 0 1px 0 rgba(255,255,255,.06), 0 18px 40px -20px rgba(0,0,0,.95); }
  /* callouts: left color bar, per the functional palette */
  .card.rec { border-left: 2px solid var(--ok); }
  .card.caution { border-left: 2px solid var(--warn); }

  /* status markers: quiet colored text, no pill chrome — the word carries the
     meaning, color reinforces it */
  .badge { display: inline; font: 500 .78rem/1.5 var(--font-mono); padding: 0; color: var(--muted); vertical-align: baseline; }
  .badge.reviewed, .badge.high, .badge.held { color: var(--ok); }
  .badge.drafted, .badge.medium, .badge.weakened { color: var(--warn); }
  .badge.low, .badge.overturned { color: var(--bad); }
  .badge.stub, .badge.beta { color: var(--exp); }

  ul { padding-left: 1.2rem; }
  li { margin: .3rem 0; }
  .rows > * { display: block; padding: .9rem 0; border-top: 1px solid var(--line); margin: 0; }
  .rows > *:last-child { border-bottom: 1px solid var(--line); }
  a.row { text-decoration: none; color: inherit; }
  a.row { transition: background .14s; border-radius: 4px; }
  a.row:hover { background: color-mix(in srgb, var(--card) 60%, transparent); }
  a.row:hover .row-title { color: var(--accent); }
  .hero { padding: 1.6rem 0 .5rem; }
  .hero p { max-width: 46rem; font-size: 1.06rem; }

  /* the stat line — numbers inline, no boxes */
  .statline { display: flex; flex-wrap: wrap; gap: .4rem 1.6rem; margin: 1.4rem 0 1.6rem; padding: 0; }
  .statline a { text-decoration: none; color: var(--muted); font: 400 .82rem var(--font-mono); }
  .statline a strong { display: block; font: 700 1.45rem/1.3 var(--font-head); color: var(--bright); }
  .statline a:hover { color: var(--fg); }
  .statline a:hover strong { color: var(--accent); }

  /* the flagship widget — one accent bar, nothing else */
  .card.pick { border-left: 2px solid var(--accent); }

  /* buttons — primary solid, secondary ghost; rectangular soft corners, never pills */
  input, textarea, button, select { font: inherit; color: inherit; }
  button, .btn { display: inline-block; background: var(--primary); color: var(--on-primary); border: 1px solid transparent; border-radius: 4px; padding: .5rem 1rem; cursor: pointer; font: 600 .85rem var(--font-mono); text-decoration: none;
    transition: box-shadow .16s ease-out, background .16s, transform .1s; box-shadow: 0 8px 24px -14px rgba(80,250,123,.5); }
  button:hover, .btn:hover { background: color-mix(in srgb, var(--primary) 90%, white); box-shadow: 0 10px 32px -12px rgba(80,250,123,.65); }
  button:active, .btn:active { transform: translateY(1px); }
  .btn.ghost, button.ghost { background: transparent; color: var(--fg); border-color: var(--line-strong); font-weight: 500; box-shadow: none; }
  .btn.ghost:hover, button.ghost:hover { border-color: var(--muted); background: var(--card); }
  textarea { width: 100%; min-height: 12rem; background: var(--code-bg); border: 1px solid var(--line); border-radius: 8px; padding: .8rem; font: 400 13px/1.55 var(--font-mono); }
  select { background: var(--card); border: 1px solid var(--line); border-radius: 4px; padding: .4rem .6rem; }
  textarea:focus, select:focus, input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 35%, transparent); }
  fieldset { border: 1px solid var(--line); border-radius: 8px; padding: .8rem 1rem; margin: .8rem 0; }
  legend { color: var(--muted); padding: 0 .4rem; }
  label { margin-right: 1rem; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr)); gap: .8rem; }
  .prose { max-width: 46rem; }
  .prose h1 { font-size: 1.5rem; margin-top: 1.8rem; }
  .prose h2 { font-size: 1.25rem; margin-top: 1.8rem; }
  .prose h3 { font-size: 1.05rem; }
  .prose img { max-width: 100%; border-radius: 8px; }

  /* terminal window (the hero demo + doctor output) */
  .term { background: var(--code-bg); border: 1px solid var(--line); border-radius: 8px; overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.05), 0 30px 70px -30px rgba(0,0,0,.95), 0 0 70px -28px rgba(80,250,123,.28); }
  .term-bar { display: flex; align-items: center; gap: .45rem; padding: .5rem .8rem; border-bottom: 1px solid var(--line); }
  .term-bar i { width: 9px; height: 9px; border-radius: 50%; background: var(--line-strong); }
  .term-bar i:nth-child(1) { background: #b3524d; } .term-bar i:nth-child(2) { background: #ad8a3b; } .term-bar i:nth-child(3) { background: #3f9954; }
  .term-bar span { margin-left: .4rem; font: 400 .72rem var(--font-mono); color: var(--muted); }
  .term pre { border: 0; border-radius: 0; margin: 0; font-size: 12.5px; line-height: 1.6; }
  .t-p { color: var(--accent); }          /* prompt / command */
  .t-ok { color: var(--ok); }
  .t-warn { color: var(--warn); }
  .t-dim { color: var(--muted); }
  .mark-ok { color: var(--ok); }
  .mark-warn { color: var(--warn); }
  .mark-dim { color: var(--muted); }

  .blink { animation: blink 1.2s steps(1) infinite; color: var(--accent); font-weight: 400; }
  @keyframes blink { 50% { opacity: 0; } }

  .statusline { display: flex; gap: .6rem; flex-wrap: wrap; align-items: center; font: 400 .78rem var(--font-mono); color: var(--muted); background: var(--card); border-radius: 4px; padding: .45rem .7rem !important; margin-top: 1rem; }
  .statusline .mode { background: var(--accent); color: var(--on-primary); font-weight: 700; padding: .05rem .5rem; border-radius: 3px; }

  ::selection { background: var(--accent); color: var(--on-primary); }
  * { scrollbar-width: thin; scrollbar-color: var(--line-strong) transparent; }
  .prose h4 { font-size: .95rem; }
  .card p, .card ul { max-width: 78ch; }

  @media print {
    :root { --bg: #fff; --card: #f5f7f9; --code-bg: #f5f7f9; --line: #c8ccd2; --line-strong: #9aa1a9;
      --fg: #111; --bright: #000; --muted: #444; --accent: #0645ad; }
    html { color-scheme: light; }
    header, aside, .mobile-nav, footer, .copy-btn, .skip, .search { display: none !important; }
    .shell { display: block; }
    a { text-decoration: underline; }
    h1 { background: none; color: var(--bright); -webkit-text-fill-color: initial; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { transition-duration: .01ms !important; animation-duration: .01ms !important; }
    html { scroll-behavior: auto !important; }
  }
</style>
